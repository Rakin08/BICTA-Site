# ─────────────────────────────────────────────────────────────────────
# BICTA — Master Environment Variables
# Copy this file to .env and fill in your real values
# ─────────────────────────────────────────────────────────────────────

# ── Sanity CMS (from sanity.io/manage → your project) ────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=ouj7m9p4
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=                        # create at sanity.io/manage → API → Tokens
SANITY_REVALIDATE_SECRET=pick_any_random_string_here

# ── Railway MySQL (your existing database) ────────────────────────────
DATABASE_URL=mysql://root:PASSWORD@zephyr.proxy.rlwy.net:11251/railway

# ── Kimi OAuth (your auth provider credentials) ──────────────────────
APP_ID=
APP_SECRET=
KIMI_AUTH_URL=https://account.kimi.ai
KIMI_OPEN_URL=https://kimi.ai
OWNER_UNION_ID=

# ── Frontend API URL (where is the Hono backend running?) ────────────
# For Docker local: http://localhost:3001
# For Railway prod:  https://your-backend.railway.app
NEXT_PUBLIC_BICTA_API_URL=http://localhost:3001
BICTA_API_URL=http://localhost:3001
