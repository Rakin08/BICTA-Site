# ─── Database (Railway MySQL) ─────────────────────────────────────────
DATABASE_URL=mysql://root:PASSWORD@zephyr.proxy.rlwy.net:11251/railway

# ─── OAuth (Kimi / your auth provider) ───────────────────────────────
APP_ID=your_app_id
APP_SECRET=your_app_secret
KIMI_AUTH_URL=https://account.kimi.ai
KIMI_OPEN_URL=https://kimi.ai
OWNER_UNION_ID=your_union_id

# ─── Server ───────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
